  sejourId            String        @map("sejour_id") @db.Uuid
  titre               String        @db.VarChar(255)
  description         String?       @db.Text
  dateDebut           DateTime      @map("date_debut") @db.Date
  dateFin             DateTime      @map("date_fin") @db.Date
  nombreEleves        Int           @map("nombre_eleves")
  nombreAccompagnateurs  Int?      @map("nombre_accompagnateurs")
  heureArrivee           String?   @map("heure_arrivee") @db.VarChar(10)
  heureDepart            String?   @map("heure_depart") @db.VarChar(10)
  transportAller         String?   @map("transport_aller") @db.VarChar(30)
  transportSurPlace      Boolean?  @map("transport_sur_place")
  activitesSouhaitees    String?   @map("activites_souhaitees") @db.Text
  informationsComplementaires String? @map("informations_complementaires") @db.Text
  budgetMaxParEleve      Float?    @map("budget_max_par_eleve")
  villeHebergement    String        @map("ville_hebergement") @db.VarChar(255)
  regionCible         String        @default("") @map("region_cible") @db.VarChar(255)
  dateButoireReponse  DateTime?     @map("date_butoire_reponse") @db.Date
  statut              StatutDemande @default(OUVERTE)
  enseignantId        String        @map("enseignant_id") @db.Uuid
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  enseignant User     @relation("DemandesCreer", fields: [enseignantId], references: [id], onDelete: Cascade)
  sejour     Sejour   @relation(fields: [sejourId], references: [id], onDelete: Cascade)
  devis      Devis[]
  demandesIgnorees DemandeIgnoree[]
  centreDestinataire   CentreHebergement? @relation("DemandesDestinees", fields: [centreDestinataireId], references: [id], onDelete: SetNull)
