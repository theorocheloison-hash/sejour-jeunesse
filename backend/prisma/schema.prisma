// ============================================================
// Prisma Schema — Séjour Jeunesse
// Base de données : PostgreSQL 16
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUM : rôle utilisateur
// ============================================================
enum Role {
  ORGANISATEUR
  SIGNATAIRE
  AUTORITE
  PARENT
  HEBERGEUR
  ADMIN
  RESEAU
}

// ============================================================
// ENUM : statut d'un séjour
// ============================================================
enum StatutSejour {
  DRAFT
  OPTION
  SUBMITTED
  CONVENTION
  SOUMIS_RECTORAT
  SIGNE_DIRECTION
  DECLARE_TAM
}

enum TypeContexteSejour {
  SCOLAIRE
  HORS_SCOLAIRE
}

// ============================================================
// ENUM : statut d'une inscription
// ============================================================
enum StatutInscription {
  en_attente
  confirmee
  annulee
  remboursee
}

// ============================================================
// ENUM : statut d'un paiement
// ============================================================
enum StatutPaiement {
  en_attente
  valide
  refuse
  rembourse
}

// ============================================================
// ENUM : méthode de paiement
// ============================================================
enum MethodePaiement {
  CARTE
  VIREMENT
  CHEQUE
  ESPECES
  CHEQUES_VACANCES
}

// ============================================================
// ENUM : type d'hébergement
// ============================================================
enum TypeHebergement {
  chalet
  tente
  auberge
  hotel
  gite
  autre
}

// ============================================================
// ENUM : type de structure organisatrice
// ============================================================
enum TypeStructure {
  COLLEGE_LYCEE
  ECOLE_PRIMAIRE
  MAIRIE
  COLLECTIVITE_TERRITORIALE
  CENTRE_LOISIRS
  ASSOCIATION
  COMITE_ENTREPRISE
  ENTREPRISE
  MICRO_ENTREPRISE
  AUTRE
}

// ============================================================
// ENUM : source d'une Organisation
// ============================================================
enum SourceOrganisation {
  MANUAL
  APIDAE
  API_EDUCATION_NATIONALE
  API_SIRENE
  IMPORT_CSV
  IMPORT_API_EN
  RESEAU_IMPORT
}

// ============================================================
// ENUM : rôle d'un membre dans une Organisation
// ============================================================
enum RoleMembership {
  PROPRIETAIRE
  ADMINISTRATEUR
  MEMBRE
}

// ============================================================
// ENUM : statut de validation d'un claim
// ============================================================
enum ClaimStatut {
  NON_APPLICABLE
  EN_ATTENTE_DOCUMENT
  EN_ATTENTE_VALIDATION
  VALIDE
  REFUSE
}

// ============================================================
// ENUM : statut d'une relation commerciale
// ============================================================
enum StatutRelation {
  PROSPECT
  CONTACTE
  INTERESSE
  EN_NEGOCIATION
  CLIENT
  INACTIF
}

// ============================================================
// MODEL : User (utilisateurs)
// ============================================================
model User {
  id             String   @id @default(uuid()) @db.Uuid
  role           Role     @default(PARENT)
  prenom         String   @db.VarChar(100)
  nom            String   @db.VarChar(100)
  email          String   @unique @db.VarChar(255)
  motDePasse     String   @map("mot_de_passe") @db.VarChar(255)
  telephone         String?  @db.VarChar(20)
  dateNaissance     DateTime? @map("date_naissance") @db.Date
  emailVerifie      Boolean  @default(false) @map("email_verifie")
  compteValide      Boolean  @default(false) @map("compte_valide")
  tokenVerification        String?   @map("token_verification") @db.Uuid
  tokenVerificationExpires DateTime? @map("token_verification_expires")
  resetPasswordToken       String?   @map("reset_password_token") @db.Uuid
  resetPasswordExpires  DateTime? @map("reset_password_expires")
  magicLinkToken   String?   @map("magic_link_token") @db.Uuid
  magicLinkExpires DateTime? @map("magic_link_expires")
  accompagnateurTokenPending String? @map("accompagnateur_token_pending") @db.Uuid

  // Établissement scolaire (données API Éducation Nationale)
  emailRectorat          String?  @map("email_rectorat") @db.VarChar(255)
  reseauNom              String?  @map("reseau_nom") @db.VarChar(100)
  reseauNomComplet       String?  @map("reseau_nom_complet") @db.VarChar(255)

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  inscriptions  Inscription[]
  sejoursCreer  Sejour[]      @relation("SejoursCreer")
  centres       CentreHebergement[]
  demandes        DemandeDevis[]   @relation("DemandesCreer")
  messages        Message[]        @relation("MessagesAuteur")
  documentsSejour DocumentSejour[] @relation("DocumentsUploader")

  consentementsRgpd ConsentementRgpd[]
  invitationsCentreExterne InvitationCentreExterne[] @relation("InvitationsEnvoyees")
  postsJournal             PostJournal[]            @relation("postsJournal")

  memberships         Membership[]
  membershipsValidees Membership[] @relation("MembershipValidateur")
  visitesSejourHebergeur SejourVisiteHebergeur[]
  centresCollaborateur   CollaborateurCentre[] @relation("collaborateur")
  invitationsEnvoyees    CollaborateurCentre[] @relation("inviteur")

  @@map("utilisateurs")
}

// ============================================================
// MODEL : ConsentementRgpd (traçabilité DPA inscription)
// ============================================================
model ConsentementRgpd {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  role             Role
  versionDpa       String   @db.VarChar(20) @map("version_dpa")
  accepteAt        DateTime @default(now()) @map("accepte_at")
  ipAddress        String?  @map("ip_address") @db.VarChar(45)
  userAgent        String?  @map("user_agent") @db.VarChar(500)
  etablissementUai String?  @map("etablissement_uai") @db.VarChar(20)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("consentements_rgpd")
}

// ============================================================
// MODEL : Sejour (séjours)
// ============================================================
model Sejour {
  id              String       @id @default(uuid()) @db.Uuid
  titre           String       @db.VarChar(255)
  description     String?      @db.Text
  lieu            String       @db.VarChar(255)
  dateDebut       DateTime?    @map("date_debut") @db.Date
  dateFin         DateTime?    @map("date_fin") @db.Date
  placesTotales   Int          @map("places_totales")
  placesRestantes Int          @map("places_restantes")
  prix                      Decimal          @default(0) @db.Decimal(10, 2)
  statut                    StatutSejour     @default(DRAFT)
  niveauClasse              String?          @map("niveau_classe") @db.VarChar(50)
  thematiquesPedagogiques   String[]         @map("thematiques_pedagogiques")
  regionSouhaitee           String?          @map("region_souhaitee") @db.VarChar(255)
  dateButoireDevis          DateTime?        @map("date_butoire_devis") @db.Date
  dateLimiteInscription     DateTime?        @map("date_limite_inscription") @db.Date
  appelOffreStatut          AppelOffreStatut @default(BROUILLON) @map("appel_offre_statut")
  createurId                String?          @map("createur_id") @db.Uuid
  hebergementSelectionneId  String?          @map("hebergement_selectionne_id") @db.Uuid
  nombreAccompagnateurs     Int?             @map("nombre_accompagnateurs")
  heureArrivee              String?          @map("heure_arrivee") @db.VarChar(10)
  heureDepart               String?          @map("heure_depart") @db.VarChar(10)
  transportAller            String?          @map("transport_aller") @db.VarChar(30)
  transportSurPlace         Boolean?         @map("transport_sur_place")
  activitesSouhaitees       String?          @map("activites_souhaitees") @db.Text
  budgetMaxParEleve         Float?           @map("budget_max_par_eleve")
  createdAt                 DateTime         @default(now()) @map("created_at")
  updatedAt                 DateTime         @updatedAt @map("updated_at")
  inscriptionsCloturees     Boolean          @default(false) @map("inscriptions_cloturees")
  typeContexte              TypeContexteSejour @default(SCOLAIRE) @map("type_contexte")
  ageMin                    Int?             @map("age_min")
  ageMax                    Int?             @map("age_max")
  moinsde6ans               Boolean          @default(false) @map("moins_de_6_ans")
  typeAccueilACM            String?          @map("type_accueil_acm") @db.VarChar(80)
  projetEducatif            String?          @map("projet_educatif") @db.Text

  // ── Gestion directe (séjour créé par l'hébergeur sans compte organisateur) ──
  modeGestion       String    @default("COLLABORATIF") @map("mode_gestion") @db.VarChar(20)
  natureSejour      String    @default("SEJOUR") @map("nature_sejour") @db.VarChar(20)
  typeSejour        String?   @map("type_sejour") @db.VarChar(30)
  clientNom         String?   @map("client_nom") @db.VarChar(255)
  clientPrenom      String?   @map("client_prenom") @db.VarChar(255)
  clientEmail       String?   @map("client_email") @db.VarChar(255)
  clientTelephone   String?   @map("client_telephone") @db.VarChar(30)
  clientOrganisation String?  @map("client_organisation") @db.VarChar(255)
  clientOrganisationId String? @map("client_organisation_id") @db.Uuid
  clientAdresse       String?  @map("client_adresse") @db.VarChar(500)
  clientCodePostal    String?  @map("client_code_postal") @db.VarChar(10)
  clientVille         String?  @map("client_ville") @db.VarChar(255)
  deletedAt         DateTime? @map("deleted_at")
  notesInternes     String?   @map("notes_internes") @db.Text

  createur               User?              @relation("SejoursCreer", fields: [createurId], references: [id], onDelete: SetNull)
  hebergementSelectionne CentreHebergement? @relation("SejourCentreSelectionne", fields: [hebergementSelectionneId], references: [id], onDelete: SetNull)
  inscriptions           Inscription[]
  hebergements           Hebergement[]
  autorisations          AutorisationParentale[]
  accompagnateurs        AccompagnateurMission[]
  demandes               DemandeDevis[]
  devisDirect            Devis[]            @relation("DevisDirectSejour")
  messages               Message[]
  planningActivites      PlanningActivite[]
  documentsSejour        DocumentSejour[]
  lignesBudget           LigneBudgetComplementaire[]
  recettesBudget         RecetteBudget[]
  groupesSejour          GroupeSejour[]
  postsJournal           PostJournal[]
  sejourRelations        SejourRelation[]
  visitesHebergeur       SejourVisiteHebergeur[]
  rappels                Rappel[]
  activitesClient        ActiviteClient[] @relation("ActivitesClientSejour")
  ventilationsPrestataires VentilationSejourPrestataire[]

  @@index([createurId])
  @@index([statut])
  @@map("sejours")
}

// ============================================================
// MODEL : LigneBudgetComplementaire
// ============================================================
model LigneBudgetComplementaire {
  id          String   @id @default(uuid()) @db.Uuid
  sejourId    String   @map("sejour_id") @db.Uuid
  categorie   String   @db.VarChar(100)
  description String   @db.VarChar(255)
  montant     Float
  createdAt   DateTime @default(now()) @map("created_at")

  sejour Sejour @relation(fields: [sejourId], references: [id], onDelete: Cascade)

  @@map("lignes_budget_complementaires")
}

// ============================================================
// MODEL : RecetteBudget
// ============================================================
model RecetteBudget {
  id        String   @id @default(uuid()) @db.Uuid
  sejourId  String   @map("sejour_id") @db.Uuid
  source    String   @db.VarChar(100)
  montant   Float
  createdAt DateTime @default(now()) @map("created_at")

  sejour Sejour @relation(fields: [sejourId], references: [id], onDelete: Cascade)

  @@map("recettes_budget")
}

// ============================================================
// MODEL : AutorisationParentale (autorisations parentales)
// ============================================================
model AutorisationParentale {
  id              String    @id @default(uuid()) @db.Uuid
  sejourId        String    @map("sejour_id") @db.Uuid
  eleveNom        String    @map("eleve_nom") @db.VarChar(100)
  elevePrenom     String    @map("eleve_prenom") @db.VarChar(100)
  parentEmail     String?   @map("parent_email") @db.VarChar(255)
  tokenAcces        String    @unique @default(uuid()) @map("token_acces") @db.Uuid
  signeeAt          DateTime? @map("signee_at")
  signatureIpAddress  String?  @map("signature_ip_address") @db.VarChar(45)
  signatureHash       String?  @map("signature_hash") @db.VarChar(64)
  taille            Int?
  poids             Int?
  pointure          Int?
  regimeAlimentaire String?   @map("regime_alimentaire") @db.VarChar(100)
  niveauSki         String?   @map("niveau_ski") @db.VarChar(50)
  infosMedicales    String?   @map("infos_medicales") @db.Text
  rgpdAccepte       Boolean   @default(false) @map("rgpd_accepte")
  rgpdAccepteAt         DateTime? @map("rgpd_accepte_at")
  rgpdVersionCgu        String?   @map("rgpd_version_cgu") @db.VarChar(20)
  consentementMedical   Boolean   @default(false) @map("consentement_medical")
  consentementMedicalAt DateTime? @map("consentement_medical_at")
  nombreMensualites Int       @default(1) @map("nombre_mensualites")
  moyenPaiement        String?   @map("moyen_paiement") @db.VarChar(20)
  paiementValide       Boolean   @default(false) @map("paiement_valide")
  datePaiement         DateTime? @map("date_paiement")
  montantVerseTotal    Float?    @default(0) @map("montant_verse_total")
  nombreVersementsEffectues Int? @default(0) @map("nombre_versements_effectues")
  documentMedicalUrl String?  @map("document_medical_url") @db.VarChar(500)
  nomParent              String?   @map("nom_parent") @db.VarChar(255)
  telephoneUrgence       String?   @map("telephone_urgence") @db.VarChar(20)
  attestationAssuranceUrl String?  @map("attestation_assurance_url") @db.VarChar(500)
  eleveDateNaissance DateTime? @map("eleve_date_naissance") @db.Date
  emailEnvoye       Boolean   @default(false) @map("email_envoye")
  champsPersonnalises Json?   @map("champs_personnalises")
  sourceInscription String?   @map("source_inscription") @db.VarChar(20)
  createdAt         DateTime  @default(now()) @map("created_at")

  sejour  Sejour        @relation(fields: [sejourId], references: [id], onDelete: Cascade)
  groupes EleveGroupe[]

  @@map("autorisations_parentales")
}

// ============================================================
// MODEL : AccompagnateurMission (ordres de mission)
// ============================================================
model AccompagnateurMission {
  id                String    @id @default(uuid()) @db.Uuid
  sejourId          String    @map("sejour_id") @db.Uuid
  prenom            String    @db.VarChar(100)
  nom               String    @db.VarChar(100)
  email             String    @db.VarChar(255)
  telephone         String?   @db.VarChar(30)
  contactUrgenceNom String?   @map("contact_urgence_nom") @db.VarChar(200)
  contactUrgenceTel String?   @map("contact_urgence_tel") @db.VarChar(30)
  tokenAcces        String    @unique @default(uuid()) @map("token_acces") @db.Uuid
  signeeAt          DateTime? @map("signee_at")
  signatureNom      String?   @map("signature_nom") @db.VarChar(200)
  moyenTransport    String?   @map("moyen_transport") @db.VarChar(50)
  accesCollaboratif  Boolean  @default(false) @map("acces_collaboratif")
  roleCollaboratif   String?  @map("role_collaboratif") @db.VarChar(20)
  userId             String?  @map("user_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at")
  // TAM Phase 1 : qualification encadrant
  // Valeurs diplome : BAFA | BAFD | PSC1 | BPJEPS | DEJEPS | DESJEPS | CPJEPS | AUTRE | null
  // qualificationAutre : précision libre si diplome = AUTRE ou complément
  diplome             String?  @map("diplome") @db.VarChar(50)
  qualificationAutre  String?  @map("qualification_autre") @db.VarChar(255)

  sejour Sejour @relation(fields: [sejourId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accompagnateurs_missions")
}

// ============================================================
// MODEL : Hebergement (catalogue + liés à un séjour)
// ============================================================
model Hebergement {
  id          String          @id @default(uuid()) @db.Uuid
  sejourId    String?         @map("sejour_id") @db.Uuid
  nom         String          @db.VarChar(255)
  type        TypeHebergement @default(autre)
  adresse     String?         @db.VarChar(500)
  ville       String          @db.VarChar(255)
  capacite    Int
  prixParJour Decimal?        @map("prix_par_jour") @db.Decimal(10, 2)
  agrement    Boolean         @default(false)
  telephone   String?         @db.VarChar(20)
  email       String?         @db.VarChar(255)
  activites   String[]
  description String?         @db.Text
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  sejour Sejour? @relation(fields: [sejourId], references: [id], onDelete: Cascade)

  @@map("hebergements")
}

// ============================================================
// MODEL : Inscription (inscriptions)
// ============================================================
model Inscription {
  id              String            @id @default(uuid()) @db.Uuid
  sejourId        String            @map("sejour_id") @db.Uuid
  utilisateurId   String            @map("utilisateur_id") @db.Uuid
  statut          StatutInscription @default(en_attente)
  dateInscription DateTime          @default(now()) @map("date_inscription")
  remarques       String?           @db.Text

  sejour      Sejour    @relation(fields: [sejourId], references: [id], onDelete: Cascade)
  utilisateur User      @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  paiements   Paiement[]

  @@unique([sejourId, utilisateurId])
  @@map("inscriptions")
}

// ============================================================
// MODEL : Paiement (paiements)
// ============================================================
model Paiement {
  id            String          @id @default(uuid()) @db.Uuid
  inscriptionId String          @map("inscription_id") @db.Uuid
  montant       Decimal         @db.Decimal(10, 2)
  statut        StatutPaiement  @default(en_attente)
  methode       MethodePaiement?
  datePaiement  DateTime        @default(now()) @map("date_paiement")

  inscription Inscription @relation(fields: [inscriptionId], references: [id], onDelete: Cascade)

  @@map("paiements")
}

// ============================================================
// ENUM : type d'abonnement
// ============================================================
enum TypeAbonnement {
  MENSUEL
  ANNUEL
}

// ============================================================
// ENUM : statut d'abonnement
// ============================================================
enum StatutAbonnement {
  INACTIF
  ACTIF
  SUSPENDU
}

enum PlanAbonnement {
  DECOUVERTE
  ESSENTIEL
  COMPLET
}

// ============================================================
// ENUM : statut d'une demande de devis
// ============================================================
enum StatutDemande {
  OUVERTE
  FERMEE
  ANNULEE
}

// ============================================================
// ENUM : statut d'un devis
// ============================================================
enum StatutDevis {
  EN_ATTENTE
  ACCEPTE
  REFUSE
  EN_ATTENTE_VALIDATION
  SELECTIONNE
  SIGNE_DIRECTION
  NON_RETENU
  FACTURE_ACOMPTE
  FACTURE_SOLDE
}

// ============================================================
// ENUM : statut d'un appel d'offres
// ============================================================
enum AppelOffreStatut {
  BROUILLON
  OUVERT
  FERME
}

// ============================================================
// ENUM : statut d'un centre d'hébergement
// ============================================================
enum StatutCentre {
  PENDING
  ACTIVE
  SUSPENDED
}

// ============================================================
// ENUM : type de document
// ============================================================
enum TypeDocument {
  AGREMENT
  ASSURANCE
  AUTRE
}

// ============================================================
// MODEL : CentreHebergement (centres gérés par HEBERGEUR)
// ============================================================
model CentreHebergement {
  id          String       @id @default(uuid()) @db.Uuid
  nom         String       @db.VarChar(255)
  adresse     String       @db.VarChar(500)
  ville       String       @db.VarChar(255)
  codePostal  String       @map("code_postal") @db.VarChar(10)
  telephone   String?      @db.VarChar(20)
  email       String?      @db.VarChar(255)
  capacite    Int
  description String?      @db.Text
  userId              String?           @map("user_id") @db.Uuid
  statut              StatutCentre      @default(PENDING)
  abonnement          TypeAbonnement?   @map("abonnement")
  abonnementActifJusquAu DateTime?      @map("abonnement_actif_jusqua") @db.Date
  abonnementStatut    StatutAbonnement  @default(INACTIF) @map("abonnement_statut")
  planAbonnement      PlanAbonnement    @default(DECOUVERTE) @map("plan_abonnement")
  siret               String?           @map("siret") @db.VarChar(14)
  siteWeb             String?           @map("site_web") @db.VarChar(500)
  tvaIntracommunautaire String?         @map("tva_intracommunautaire") @db.VarChar(20)
  iban                String?           @db.VarChar(34)
  equipements         String[]          @default([])
  conditionsAnnulation String?          @map("conditions_annulation") @db.Text
  departement         String?           @map("departement") @db.VarChar(100)
  agrementEducationNationale String?    @map("agrement_education_nationale") @db.VarChar(50)
  typeSejours         String[]          @default([]) @map("type_sejours")
  accessiblePmr       Boolean           @default(false) @map("accessible_pmr")
  avisSecurite        String?           @map("avis_securite") @db.VarChar(50)
  thematiquesCentre   String[]          @default([]) @map("thematiques_centre")
  activitesCentre     String[]          @default([]) @map("activites_centre")
  capaciteAdultes     Int?              @map("capacite_adultes")
  periodeOuverture    String?           @map("periode_ouverture") @db.VarChar(255)
  reseau              String?           @map("reseau") @db.VarChar(100)
  apidaeId            String?           @map("apidae_id") @db.VarChar(20)
  source              String?           @map("source") @db.VarChar(20)
  imageUrl            String?           @map("image_url") @db.VarChar(500)
  brochureUrl         String?           @map("brochure_url") @db.VarChar(500)
  champsInscription   Json?             @map("champs_inscription")
  // Justificatif de revendication propre à CE centre (hébergeur déjà validé qui
  // ajoute un centre) — distinct de Membership.claimDocumentUrl (1er claim société).
  claimDocumentUrl    String?           @map("claim_document_url") @db.VarChar(500)
  claimSubmittedAt    DateTime?         @map("claim_submitted_at")
  claimSubmittedBy    String?           @map("claim_submitted_by") @db.Uuid
  mandatFacturationAccepte   Boolean   @default(false) @map("mandat_facturation_accepte")
  mandatFacturationAccepteAt DateTime? @map("mandat_facturation_accepte_at")
  mandatFacturationVersion   String?   @map("mandat_facturation_version") @db.VarChar(20)
  mandatFacturationIpAddress String?   @map("mandat_facturation_ip") @db.VarChar(45)
  mandatFacturationUserAgent String?   @map("mandat_facturation_ua") @db.VarChar(500)
  organisationId      String?           @map("organisation_id") @db.Uuid
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  user              User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  organisation      Organisation?   @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  disponibilites    Disponibilite[]
  documents         Document[]
  devis             Devis[]
  sejoursSelectionne Sejour[]       @relation("SejourCentreSelectionne")
  invitationsCollaboration InvitationCollaboration[]
  produitsCatalogue ProduitCatalogue[]
  demandesIgnorees DemandeIgnoree[]
  demandesDestinees DemandeDevis[] @relation("DemandesDestinees")
  clients          Client[]
  invitationsAdmin InvitationHebergement[] @relation("InvitationCentreExistant")
  devisLibres      DevisLibre[]
  activitesClients ActiviteClient[]
  facturesPrestataires FacturePrestataire[]
  collaborateurs   CollaborateurCentre[]
  @@map("centres_hebergement")
}

// ============================================================
// MODEL : CollaborateurCentre (multi-user hébergeur — permissions par module)
// ============================================================
model CollaborateurCentre {
  id            String    @id @default(uuid()) @db.Uuid
  centreId      String    @map("centre_id") @db.Uuid
  userId        String?   @map("user_id") @db.Uuid
  inviteEmail   String    @map("invite_email") @db.VarChar(255)
  inviteToken   String    @unique @default(uuid()) @map("invite_token") @db.Uuid
  permissions   Json      @default("{}") // { planning: 'WRITE', sejours: 'READ', devis: 'NONE', crm: 'NONE', facturation: 'NONE', parametres: 'NONE' }
  invitePar     String    @map("invite_par") @db.Uuid
  acceptedAt    DateTime? @map("accepted_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  centre        CentreHebergement @relation(fields: [centreId], references: [id], onDelete: Cascade)
  user          User?             @relation("collaborateur", fields: [userId], references: [id], onDelete: SetNull)
  inviteur      User              @relation("inviteur", fields: [invitePar], references: [id])

  @@unique([centreId, inviteEmail])
  @@index([userId])
  @@index([centreId])
  @@map("collaborateurs_centre")
}

// ============================================================
