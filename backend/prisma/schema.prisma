// ============================================================
// MODEL : DemandeIgnoree (demande ignorée par un centre)
// ============================================================
model DemandeIgnoree {
  id         String   @id @default(uuid()) @db.Uuid
  demandeId  String   @map("demande_id") @db.Uuid
  centreId   String   @map("centre_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  demande DemandeDevis      @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  centre  CentreHebergement @relation(fields: [centreId], references: [id], onDelete: Cascade)

  @@unique([demandeId, centreId])
  @@map("demandes_ignorees")
}

// ============================================================
// MODEL : Devis (réponse d'un centre à une demande)
// ============================================================
model Devis {
  id                    String       @id @default(uuid()) @db.Uuid
  demandeId             String?      @map("demande_id") @db.Uuid
  sejourDirectId        String?      @map("sejour_direct_id") @db.Uuid
  tokenSignature        String?      @unique @default(uuid()) @map("token_signature") @db.Uuid
  centreId              String       @map("centre_id") @db.Uuid
  montantTotal          Decimal      @map("montant_total") @db.Decimal(10, 2)
  montantParEleve       Decimal      @map("montant_par_eleve") @db.Decimal(10, 2)
  description           String?      @db.Text
  conditionsAnnulation  String?      @map("conditions_annulation") @db.Text
  statut                StatutDevis  @default(EN_ATTENTE)
  documentUrl           String?      @map("document_url") @db.VarChar(500)
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  // Informations entreprise
  nomEntreprise         String?      @map("nom_entreprise") @db.VarChar(255)
  adresseEntreprise     String?      @map("adresse_entreprise") @db.Text
  siretEntreprise       String?      @map("siret_entreprise") @db.VarChar(20)
  emailEntreprise       String?      @map("email_entreprise") @db.VarChar(255)
  telEntreprise         String?      @map("tel_entreprise") @db.VarChar(20)

  // TVA et montants calculés
  tauxTva               Float?       @default(0) @map("taux_tva")
  montantHT             Float?       @map("montant_ht")
  montantTVA            Float?       @map("montant_tva")
  montantTTC            Float?       @map("montant_ttc")

  // Acompte
  pourcentageAcompte    Float?       @default(30) @map("pourcentage_acompte")
  montantAcompte        Float?       @map("montant_acompte")
  montantSolde          Float?       @map("montant_solde")
  acompteVerse          Boolean      @default(false) @map("acompte_verse")
  dateVersementAcompte  DateTime?    @map("date_versement_acompte")

  // Facturation
  estFacture            Boolean      @default(false) @map("est_facture")
  dateFacture           DateTime?    @map("date_facture")
  numeroDevis           String?      @map("numero_devis") @db.VarChar(50)
  numeroFacture         String?      @map("numero_facture") @db.VarChar(50)
  // Émetteur légal résolu à la facturation : organisationId ?? centreId (rempli à la facturation)
  emetteurId            String?      @map("emetteur_id") @db.Uuid

  // Type de soumission
  typeDevis             String       @default("PLATEFORME") @map("type_devis") @db.VarChar(20)

  // Type de document : DEVIS | FACTURE_ACOMPTE | FACTURE_SOLDE
  typeDocument          String       @default("DEVIS") @map("type_document") @db.VarChar(30)
  signatureDirecteur      String?   @map("signature_directeur") @db.Text
  signatureDocumentUrl    String?   @map("signature_document_url")
  dateSignatureDirecteur  DateTime? @map("date_signature_directeur")
  nomSignataireDirecteur  String?   @map("nom_signataire_directeur") @db.VarChar(255)
  signatureIpAddress  String?  @map("signature_ip_address") @db.VarChar(45)
  signatureUserAgent  String?  @map("signature_user_agent") @db.VarChar(500)
  signatureHash       String?  @map("signature_hash") @db.VarChar(64)

  relanceEnvoyeeAt DateTime? @map("relance_envoyee_at")
  montantVerseTotal Float @default(0) @map("montant_verse_total")

  // ── Devis complémentaire : payeur additionnel (AS, Mairie…) avec destinataire propre ──
  isComplementaire      Boolean  @default(false) @map("is_complementaire")
  destinataireNom       String?  @map("destinataire_nom") @db.VarChar(255)
  destinataireAdresse   String?  @map("destinataire_adresse") @db.Text
  destinataireCodePostal String? @map("destinataire_code_postal") @db.VarChar(10)
  destinataireVille     String?  @map("destinataire_ville") @db.VarChar(255)
  destinataireSiret     String?  @map("destinataire_siret") @db.VarChar(14)
  destinataireEmail     String?  @map("destinataire_email") @db.VarChar(255)

  demande DemandeDevis?     @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  sejourDirect    Sejour?           @relation("DevisDirectSejour", fields: [sejourDirectId], references: [id], onDelete: Cascade)
  centre  CentreHebergement @relation(fields: [centreId], references: [id], onDelete: Cascade)
  lignes  LigneDevis[]
  versements VersementPaiement[]
  factures   Facture[]

  @@index([centreId])
  @@index([statut])
  @@index([emetteurId])
  // Garde-fou unicité numéro de facture par émetteur : index unique partiel créé en SQL
  // (CREATE UNIQUE INDEX ... WHERE numero_facture IS NOT NULL) — non exprimable en Prisma.
  @@map("devis")
}

// ============================================================
// MODEL : SequenceNumero (compteur séquentiel atomique par émetteur)
// Table technique sans relation. Une séquence par (emetteur, année, type de doc).
// typeDoc : 'DEVIS' | 'FACTURE' (acompte ET solde partagent la séquence FACTURE).
// ============================================================
model SequenceNumero {
  id            String   @id @default(uuid()) @db.Uuid
  emetteurId    String   @map("emetteur_id") @db.Uuid
  annee         Int
  typeDoc       String   @map("type_doc") @db.VarChar(20)
  dernierNumero Int      @default(0) @map("dernier_numero")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([emetteurId, annee, typeDoc])
  @@map("sequence_numero")
}

// ============================================================
// MODEL : VersementPaiement (suivi des paiements reçus)
// ============================================================
model VersementPaiement {
  id            String   @id @default(uuid()) @db.Uuid
  devisId       String   @map("devis_id") @db.Uuid
  factureId     String?  @map("facture_id") @db.Uuid
  montant       Float
  datePaiement  DateTime @map("date_paiement") @db.Date
  reference     String?  @db.VarChar(255)
  modePaiement  MethodePaiement? @map("mode_paiement")
  createdAt     DateTime @default(now()) @map("created_at")

  devis   Devis    @relation(fields: [devisId], references: [id], onDelete: Cascade)
  facture Facture? @relation(fields: [factureId], references: [id])

  @@index([factureId])
  @@map("versements_paiement")
}

// ============================================================
// MODEL : Facture (snapshot immuable — Lot 1)
// Émise depuis un Devis, fige émetteur/destinataire/montants au moment de l'émission.
// Le Devis reste modifiable après l'acompte ; le solde se calcule sur le total révisé − acompte.
// ============================================================
model Facture {
  id               String   @id @default(uuid()) @db.Uuid
  devisId          String   @map("devis_id") @db.Uuid
  sejourId         String?  @map("sejour_id") @db.Uuid
  emetteurId       String   @map("emetteur_id") @db.Uuid
  numero           String   @db.VarChar(50)
  typeFacture      String   @map("type_facture") @db.VarChar(20) // ACOMPTE | SOLDE
  dateEmission     DateTime @map("date_emission")
  // Snapshot émetteur (figé)
  emetteurNom      String   @map("emetteur_nom") @db.VarChar(255)
  emetteurAdresse  String?  @map("emetteur_adresse") @db.Text
  emetteurSiret    String?  @map("emetteur_siret") @db.VarChar(14)
  emetteurTva      String?  @map("emetteur_tva") @db.VarChar(20)
  emetteurEmail    String?  @map("emetteur_email") @db.VarChar(255)
  emetteurTel      String?  @map("emetteur_tel") @db.VarChar(20)
  emetteurIban     String?  @map("emetteur_iban") @db.VarChar(34)
  // Snapshot destinataire (figé)
  destinataireNom     String   @map("destinataire_nom") @db.VarChar(255)
  destinataireAdresse String?  @map("destinataire_adresse") @db.Text
  destinataireSiret   String?  @map("destinataire_siret") @db.VarChar(14)
  destinataireEmail   String?  @map("destinataire_email") @db.VarChar(255)
  // Montants figés du devis AU MOMENT de l'émission
  montantHT        Float    @map("montant_ht")
  montantTVA       Float    @map("montant_tva")
  montantTTC       Float    @map("montant_ttc")
  tauxTva          Float    @map("taux_tva")
  // Montant de CETTE facture
  montantFacture   Float    @map("montant_facture")
  pourcentageAcompte Float? @map("pourcentage_acompte")
  // Lien acompte → solde
  factureAcompteId String?  @map("facture_acompte_id") @db.Uuid
  montantAcompteDejaFacture Float? @map("montant_acompte_deja_facture")
  // Suivi paiement de CETTE facture
  montantVerseTotal Float   @default(0) @map("montant_verse_total")
  acompteVerse      Boolean @default(false) @map("acompte_verse")
  dateVersement     DateTime? @map("date_versement")
  // Conditions
  conditionsAnnulation String? @map("conditions_annulation") @db.Text
  pdfUrl           String?  @map("pdf_url") @db.VarChar(500)
  // Avoir (note de crédit) — Lot 3
  factureAnnuleeId String?  @unique @map("facture_annulee_id") @db.Uuid
  motifAvoir       String?  @map("motif_avoir") @db.Text
  createdAt        DateTime @default(now()) @map("created_at")

  devis            Devis    @relation(fields: [devisId], references: [id])
  factureAcompte   Facture? @relation("FactureAcompte", fields: [factureAcompteId], references: [id])
  facturesSolde    Facture[] @relation("FactureAcompte")
  // Relation auto-référencée 1-1 : facture annulée par cet avoir
  factureAnnulee   Facture?  @relation("FactureAvoir", fields: [factureAnnuleeId], references: [id])
  avoirAssocie     Facture?  @relation("FactureAvoir")
  lignes           LigneFacture[]
  versements       VersementPaiement[]

  @@unique([emetteurId, numero])
  @@index([devisId])
  @@index([sejourId])
  @@map("factures")
}

model LigneFacture {
  id           String  @id @default(uuid()) @db.Uuid
  factureId    String  @map("facture_id") @db.Uuid
  description  String  @db.Text
  quantite     Float
  prixUnitaire Float   @map("prix_unitaire")
  tva          Float   @default(0)
  totalHT      Float   @map("total_ht")
  totalTTC     Float   @map("total_ttc")
  facture      Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)

  @@map("lignes_facture")
}

// ============================================================
// MODEL : DevisLibre (devis clients particuliers — mariages, séminaires)
