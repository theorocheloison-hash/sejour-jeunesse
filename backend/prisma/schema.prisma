// ============================================================
// ENUM : type de document de séjour (collaboration)
// ============================================================
enum TypeDocumentSejour {
  PROGRAMME
  TRANSPORT
  ASSURANCE
  FACTURE
  AUTRE
}

// ============================================================
// MODEL : Message (messagerie collaboration)
// ============================================================
model Message {
