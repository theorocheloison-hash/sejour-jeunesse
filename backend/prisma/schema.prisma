  @@map("messages")
}

// ============================================================
// MODEL : PlanningActivite (planning collaboration)
// ============================================================
model PlanningActivite {
  id          String   @id @default(uuid()) @db.Uuid
  sejourId    String   @map("sejour_id") @db.Uuid
  date        DateTime @db.Date
  heureDebut  String   @map("heure_debut") @db.VarChar(5)
  heureFin    String   @map("heure_fin") @db.VarChar(5)
  titre       String   @db.VarChar(255)
  description String?  @db.Text
  responsable String?  @db.VarChar(255)
  couleur     String?  @db.VarChar(50)
  groupeId    String?  @map("groupe_id") @db.Uuid
  estManuelle   Boolean  @default(true) @map("est_manuelle")
  estCollective Boolean  @default(false) @map("est_collective")
  createdAt   DateTime @default(now()) @map("created_at")

  sejour Sejour        @relation(fields: [sejourId], references: [id], onDelete: Cascade)
  groupe GroupeSejour? @relation("ActivitesGroupe", fields: [groupeId], references: [id], onDelete: SetNull)

  @@map("planning_activites")
}

// ============================================================
// MODEL : GroupeSejour (groupes d'élèves pour planning IA)
// ============================================================
model GroupeSejour {
  id        String   @id @default(uuid()) @db.Uuid
  sejourId  String   @map("sejour_id") @db.Uuid
  nom       String   @db.VarChar(100)
  couleur   String   @db.VarChar(50)
  taille    Int
  createdAt DateTime @default(now()) @map("created_at")

  sejour    Sejour             @relation(fields: [sejourId], references: [id], onDelete: Cascade)
  activites PlanningActivite[] @relation("ActivitesGroupe")
  eleves    EleveGroupe[]

  @@index([sejourId])
  @@map("groupes_sejour")
}

// ============================================================
// MODEL : EleveGroupe (affectation élève → groupe)
// ============================================================
model EleveGroupe {
  id             String               @id @default(uuid()) @db.Uuid
  groupeId       String               @map("groupe_id") @db.Uuid
  autorisationId String               @map("autorisation_id") @db.Uuid
  createdAt      DateTime             @default(now()) @map("created_at")

  groupe       GroupeSejour          @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  autorisation AutorisationParentale @relation(fields: [autorisationId], references: [id], onDelete: Cascade)

  @@unique([groupeId, autorisationId])
  @@index([groupeId])
  @@map("eleves_groupes")
}

// ============================================================
// MODEL : DocumentSejour (documents collaboration)
// ============================================================
model DocumentSejour {
  id         String            @id @default(uuid()) @db.Uuid
  sejourId   String            @map("sejour_id") @db.Uuid
  uploaderId String            @map("uploader_id") @db.Uuid
  nom        String            @db.VarChar(255)
  type       TypeDocumentSejour @default(AUTRE)
  url        String            @db.VarChar(500)
  createdAt  DateTime          @default(now()) @map("created_at")

  sejour   Sejour @relation(fields: [sejourId], references: [id], onDelete: Cascade)
  uploader User   @relation("DocumentsUploader", fields: [uploaderId], references: [id], onDelete: Cascade)

  @@map("documents_sejour")
}

// ============================================================
// MODEL : InvitationCollaboration (hébergeur invite enseignant)
// ============================================================
model InvitationCollaboration {
  id                  String             @id @default(uuid()) @db.Uuid
  token               String             @unique @default(uuid()) @db.Uuid
  centreId            String             @map("centre_id") @db.Uuid
  centre              CentreHebergement  @relation(fields: [centreId], references: [id], onDelete: Cascade)
  emailEnseignant     String             @map("email_enseignant") @db.VarChar(255)
  titreSejourSuggere  String             @map("titre_sejour_suggere") @db.VarChar(255)
  dateDebut           DateTime           @map("date_debut") @db.Date
  dateFin             DateTime           @map("date_fin") @db.Date
  nbElevesEstime      Int                @map("nb_eleves_estime")
  message             String?            @db.Text
  niveauClasse              String?   @map("niveau_classe") @db.VarChar(50)
  nombreAccompagnateurs     Int?      @map("nombre_accompagnateurs")
  thematiquesPedagogiques   String[]  @default([]) @map("thematiques_pedagogiques")
  heureArrivee              String?   @map("heure_arrivee") @db.VarChar(10)
  heureDepart               String?   @map("heure_depart") @db.VarChar(10)
  transportAller            String?   @map("transport_aller") @db.VarChar(30)
  transportSurPlace         Boolean?  @map("transport_sur_place")
  activitesSouhaitees       String?   @map("activites_souhaitees") @db.Text
  budgetMaxParEleve         Float?    @map("budget_max_par_eleve")
  etablissementUai      String?   @map("etablissement_uai") @db.VarChar(20)
  etablissementNom      String?   @map("etablissement_nom") @db.VarChar(255)
  etablissementAdresse  String?   @map("etablissement_adresse") @db.VarChar(500)
  etablissementVille    String?   @map("etablissement_ville") @db.VarChar(255)
  acceptedAt          DateTime?          @map("accepted_at")
  devisDraftJson   Json?   @map("devis_draft_json")
  sejourId            String?            @map("sejour_id") @db.Uuid
  createdAt           DateTime           @default(now()) @map("created_at")

  @@map("invitations_collaboration")
}

// ============================================================
// MODEL : Client (CRM hébergeur)
// ============================================================
model Client {
  id          String   @id @default(uuid()) @db.Uuid
  centreId    String   @map("centre_id") @db.Uuid
  nom         String   @db.VarChar(255)
  type        String   @default("ETABLISSEMENT_SCOLAIRE") @db.VarChar(50)
  statut      String   @default("PROSPECT") @db.VarChar(30)
  adresse     String?  @db.VarChar(500)
  ville       String?  @db.VarChar(255)
  codePostal  String?  @map("code_postal") @db.VarChar(10)
  telephone   String?  @db.VarChar(20)
  email       String?  @db.VarChar(255)
  uai         String?  @db.VarChar(20)
  academie    String?  @db.VarChar(100)
  notes       String?  @db.Text
  source      String   @default("MANUEL") @db.VarChar(20)
  organisationId String?  @map("organisation_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  centre       CentreHebergement @relation(fields: [centreId], references: [id], onDelete: Cascade)
  organisation Organisation?     @relation("ClientOrganisation", fields: [organisationId], references: [id], onDelete: SetNull)
  contacts     ContactClient[]
  rappels      Rappel[]
  sejours      SejourClient[]
  devisLibres  DevisLibre[]
  activites    ActiviteClient[]

  @@index([centreId])
  @@index([centreId, uai])
  @@index([centreId, nom])
  @@index([organisationId])
  @@map("clients")
}

model ContactClient {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  relationId String?              @map("relation_id") @db.Uuid
  prenom    String   @db.VarChar(100)
  nom       String   @db.VarChar(100)
  email     String?  @db.VarChar(255)
  telephone String?  @db.VarChar(20)
  role      String?  @db.VarChar(100)
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  client   Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  relation RelationCommerciale?  @relation("ContactsRelation", fields: [relationId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([clientId, email])
  @@index([relationId])
  @@map("contacts_clients")
}

model Rappel {
  id           String   @id @default(uuid()) @db.Uuid
  clientId     String   @map("client_id") @db.Uuid
  relationId   String?              @map("relation_id") @db.Uuid
  type         String   @db.VarChar(50)
  dateEcheance DateTime @map("date_echeance") @db.Date
  description  String   @db.Text
  statut       String   @default("A_FAIRE") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  notifiedAt   DateTime? @map("notified_at")
  sejourId     String?  @map("sejour_id") @db.Uuid
  sejour       Sejour?  @relation(fields: [sejourId], references: [id], onDelete: SetNull)

  client   Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  relation RelationCommerciale?  @relation("RappelsRelation", fields: [relationId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([relationId])
  @@map("rappels")
}

model SejourClient {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  sejourId  String   @map("sejour_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, sejourId])
  @@map("sejours_clients")
}

// ============================================================
// MODEL : InvitationCentreExterne (enseignant invite hébergeur sans compte)
// ============================================================
model InvitationCentreExterne {
  id                 String    @id @default(uuid()) @db.Uuid
  token              String    @unique @default(uuid()) @db.Uuid
  enseignantId       String    @map("enseignant_id") @db.Uuid
  emailDestinataire  String    @map("email_destinataire") @db.VarChar(255)
  nomCentre          String    @map("nom_centre") @db.VarChar(255)
  villeCentre        String    @map("ville_centre") @db.VarChar(255)
  codePostalCentre   String    @map("code_postal_centre") @db.VarChar(10)
  titreSejourSuggere String    @map("titre_sejour_suggere") @db.VarChar(255)
  dateDebut          DateTime  @map("date_debut") @db.Date
  dateFin            DateTime  @map("date_fin") @db.Date
  nbElevesEstime     Int       @map("nb_eleves_estime")
  message            String?   @db.Text
  centreId           String?   @map("centre_id") @db.Uuid
  demandeCreee       Boolean   @default(false) @map("demande_creee")
  createdAt          DateTime  @default(now()) @map("created_at")

  enseignant User @relation("InvitationsEnvoyees", fields: [enseignantId], references: [id], onDelete: Cascade)

  @@map("invitations_centre_externe")
}

// ============================================================
// MODEL : InvitationDirecteur (enseignant invite directeur non inscrit)
// ============================================================
model InvitationDirecteur {
  id                String    @id @default(uuid()) @db.Uuid
  token             String    @unique @default(uuid()) @db.Uuid
  sejourId          String    @map("sejour_id") @db.Uuid
  devisId           String?   @map("devis_id") @db.Uuid
  emailDirecteur    String    @map("email_directeur") @db.VarChar(255)
  etablissementUai  String?   @map("etablissement_uai") @db.VarChar(20)
  etablissementNom  String?   @map("etablissement_nom") @db.VarChar(255)
  enseignantPrenom  String?   @map("enseignant_prenom") @db.VarChar(100)
  sejourTitre       String?   @map("sejour_titre") @db.VarChar(255)
  organisationId   String?   @map("organisation_id") @db.Uuid
  typeContexte     String?   @map("type_contexte") @db.VarChar(20)
  organisation     Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  nomSignataire      String?   @map("nom_signataire")
  fonctionSignataire String?   @map("fonction_signataire")
  signeAt            DateTime? @map("signe_at")
  signatureIp        String?   @map("signature_ip")
  utilisedAt        DateTime? @map("utilised_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@map("invitations_directeur")
}

// ============================================================
// MODEL : PostJournal (journal de séjour — blog parents)
// ============================================================
model PostJournal {
  id        String   @id @default(uuid()) @db.Uuid
  sejourId  String   @map("sejour_id") @db.Uuid
  auteurId  String   @map("auteur_id") @db.Uuid
  contenu   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  sejour Sejour         @relation(fields: [sejourId], references: [id], onDelete: Cascade)
  auteur User           @relation("postsJournal", fields: [auteurId], references: [id])
  photos PhotoJournal[]

  @@map("posts_journal")
}

// ============================================================
// MODEL : PhotoJournal (photos d'un post du journal)
// ============================================================
model PhotoJournal {
  id     String @id @default(uuid()) @db.Uuid
  postId String @map("post_id") @db.Uuid
  url    String
  ordre  Int    @default(0)

  post PostJournal @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("photos_journal")
}

// ============================================================
// MODEL : Organisation (entité de premier ordre — refactor Phase 1)
// ============================================================
model Organisation {
  id            String              @id @default(uuid()) @db.Uuid
  siren         String?             @unique @db.VarChar(9)
  siret         String?             @db.VarChar(14)
  rna           String?             @db.VarChar(10)
  uai           String?             @db.VarChar(20)
  nom           String              @db.VarChar(255)
  raisonSociale String?             @map("raison_sociale") @db.VarChar(255)
  adresse       String?             @db.VarChar(500)
  codePostal    String?             @map("code_postal") @db.VarChar(10)
  ville         String?             @db.VarChar(255)
  departement   String?             @db.VarChar(100)
  emailContact     String?  @map("email_contact") @db.VarChar(255)
  telephoneContact String?  @map("telephone_contact") @db.VarChar(20)
  siteWeb          String?  @map("site_web") @db.VarChar(500)
  typeStructure  TypeStructure?    @map("type_structure")
  academie       String?           @db.VarChar(100)
  source         SourceOrganisation @default(MANUAL)
  sourceId       String?            @map("source_id") @db.VarChar(100)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  memberships          Membership[]
  centresHebergement   CentreHebergement[]
  clients              Client[]                @relation("ClientOrganisation")
  relationsCliente     RelationCommerciale[]   @relation("OrganisationCliente")
  relationsHebergeur   RelationCommerciale[]   @relation("OrganisationHebergeur")
  invitationsDirecteur InvitationDirecteur[]

  @@index([siren])
  @@index([siret])
  @@index([uai])
  @@index([rna])
  @@index([nom])
  @@map("organisations")
}

// ============================================================
// MODEL : Membership (humain ↔ organisation)
// ============================================================
model Membership {
  id              String          @id @default(uuid()) @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  organisationId  String          @map("organisation_id") @db.Uuid
  role            RoleMembership  @default(MEMBRE)
  isPrimary       Boolean         @default(false) @map("is_primary")
  claimStatut         ClaimStatut @default(NON_APPLICABLE) @map("claim_statut")
  claimDocumentUrl    String?     @map("claim_document_url") @db.VarChar(500)
  claimSiretExtrait   String?     @map("claim_siret_extrait") @db.VarChar(14)
  claimValidatedById  String?     @map("claim_validated_by_id") @db.Uuid
  claimValidatedAt    DateTime?   @map("claim_validated_at")
  claimRefuseRaison   String?     @map("claim_refuse_raison") @db.Text
  claimSubmittedAt    DateTime?   @map("claim_submitted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation    Organisation   @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  validateur      User?          @relation("MembershipValidateur", fields: [claimValidatedById], references: [id])

  @@unique([userId, organisationId])
  @@index([userId])
  @@index([organisationId])
  @@index([claimStatut])
  @@map("memberships")
}

// ============================================================
// MODEL : RelationCommerciale (CRM — remplacera Client en Phase 1bis)
// ============================================================
model RelationCommerciale {
  id                       String          @id @default(uuid()) @db.Uuid
  organisationHebergeurId  String          @map("organisation_hebergeur_id") @db.Uuid
  organisationClienteId    String          @map("organisation_cliente_id") @db.Uuid
  statut                   StatutRelation  @default(PROSPECT)
  notes                    String?         @db.Text
  source                   String          @default("MANUEL") @db.VarChar(20)
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")

  organisationHebergeur Organisation @relation("OrganisationHebergeur", fields: [organisationHebergeurId], references: [id], onDelete: Cascade)
  organisationCliente   Organisation @relation("OrganisationCliente", fields: [organisationClienteId], references: [id], onDelete: Cascade)
  sejourRelations       SejourRelation[]
  rappels               Rappel[]         @relation("RappelsRelation")
  contacts              ContactClient[]  @relation("ContactsRelation")

  @@unique([organisationHebergeurId, organisationClienteId])
  @@index([organisationHebergeurId])
  @@index([organisationClienteId])
  @@map("relations_commerciales")
}

// ============================================================
// MODEL : SejourRelation (remplacera SejourClient en Phase 1bis)
// ============================================================
model SejourRelation {
  id                    String   @id @default(uuid()) @db.Uuid
  relationId            String   @map("relation_id") @db.Uuid
  sejourId              String   @map("sejour_id") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at")

  relation              RelationCommerciale @relation(fields: [relationId], references: [id], onDelete: Cascade)
  sejour                Sejour              @relation(fields: [sejourId], references: [id], onDelete: Cascade)

  @@unique([relationId, sejourId])
  @@map("sejours_relations")
}

model ActiviteClient {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @map("client_id") @db.Uuid
  centreId    String   @map("centre_id") @db.Uuid
  type        String   @db.VarChar(30)
  description String   @db.Text
  metadata    Json?
  userId      String?  @map("user_id") @db.Uuid
  sejourId    String?  @map("sejour_id") @db.Uuid
  sejour      Sejour?  @relation("ActivitesClientSejour", fields: [sejourId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")

  client Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  centre CentreHebergement @relation(fields: [centreId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt(sort: Desc)])
  @@index([centreId])
  @@map("activites_client")
}

// ============================================================
// MODEL : SejourVisiteHebergeur (tracking dernière visite par onglet)
// ============================================================
model SejourVisiteHebergeur {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  sejourId  String   @map("sejour_id") @db.Uuid
  onglet    String   @db.VarChar(30)
  visitedAt DateTime @map("visited_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sejour Sejour @relation(fields: [sejourId], references: [id], onDelete: Cascade)

  @@unique([userId, sejourId, onglet])
  @@map("sejour_visites_hebergeur")
}

// ============================================================
// MODEL : FacturePrestataire
// Facture reçue d'un prestataire externe, peut couvrir N séjours.
// ============================================================
model FacturePrestataire {
  id              String    @id @default(uuid()) @db.Uuid
  centreId        String    @map("centre_id") @db.Uuid
  nomPrestataire  String    @map("nom_prestataire") @db.VarChar(255)
  typeCharge      String    @map("type_charge") @db.VarChar(50)
  // Valeurs attendues : GUIDE_AMM | ESF | TRANSPORT | ACTIVITE | LOCATION | RESTAURATION | AUTRE
  numeroFacture   String?   @map("numero_facture") @db.VarChar(100)
  dateFacture     DateTime? @map("date_facture") @db.Date
  montantTotalTTC Float     @map("montant_total_ttc")
  fichierUrl      String?   @map("fichier_url") @db.VarChar(500)
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  centre       CentreHebergement              @relation(fields: [centreId], references: [id], onDelete: Cascade)
  ventilations VentilationSejourPrestataire[]

  @@index([centreId])
  @@index([centreId, dateFacture])
  @@map("factures_prestataires")
}

// ============================================================
// MODEL : VentilationSejourPrestataire
// Part d'une FacturePrestataire allouée à un séjour.
// ============================================================
model VentilationSejourPrestataire {
  id          String   @id @default(uuid()) @db.Uuid
  factureId   String   @map("facture_prestataire_id") @db.Uuid
  sejourId    String   @map("sejour_id") @db.Uuid
  montantTTC  Float    @map("montant_ttc")
  createdAt   DateTime @default(now()) @map("created_at")

  facture FacturePrestataire @relation(fields: [factureId], references: [id], onDelete: Cascade)
  sejour  Sejour             @relation(fields: [sejourId], references: [id], onDelete: Cascade)

  @@index([sejourId])
  @@index([factureId])
  @@map("ventilations_sejour_prestataire")
}
