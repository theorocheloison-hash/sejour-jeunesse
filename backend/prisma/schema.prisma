model VersementDevisLibre {
  id           String   @id @default(uuid()) @db.Uuid
  devisLibreId String   @map("devis_libre_id") @db.Uuid
  montant      Float
  datePaiement DateTime @map("date_paiement") @db.Date
  reference    String?  @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  devisLibre DevisLibre @relation(fields: [devisLibreId], references: [id], onDelete: Cascade)

  @@map("versements_devis_libre")
}

// ============================================================
// MODEL : LigneDevis (lignes d'un devis)
// ============================================================
model LigneDevis {
