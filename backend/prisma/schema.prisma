// ============================================================
// MODEL : InvitationHebergement (invitations envoyées)
// ============================================================
model InvitationHebergement {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @db.VarChar(255)
  nomCentre   String    @map("nom_centre") @db.VarChar(255)
  token       String    @unique @default(uuid()) @db.Uuid
  utilisedAt  DateTime? @map("utilised_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Centre pré-existant à rattacher
  centreExistantId    String?   @map("centre_existant_id") @db.Uuid
  centreExistant      CentreHebergement? @relation("InvitationCentreExistant", fields: [centreExistantId], references: [id], onDelete: SetNull)

  // Données de pré-création d'un nouveau centre (si centreExistantId null)
  centrePrecreerNom         String?  @map("centre_precreer_nom") @db.VarChar(255)
  centrePrecreerAdresse     String?  @map("centre_precreer_adresse") @db.VarChar(500)
  centrePrecreerVille       String?  @map("centre_precreer_ville") @db.VarChar(255)
  centrePrecreerCodePostal  String?  @map("centre_precreer_code_postal") @db.VarChar(10)
  centrePrecreerCapacite    Int?     @map("centre_precreer_capacite")
  centrePrecreerSiret       String?  @map("centre_precreer_siret") @db.VarChar(14)
